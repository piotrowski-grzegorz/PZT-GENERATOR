<Window x:Class="PztGenerator.MpzpSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PZT - wymagania MPZP"
        Width="620"
        Height="430"
        MinWidth="560"
        MinHeight="400"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top">
            <TextBlock Text="Wymagania MPZP"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6" />
            <TextBlock Text="{Binding SiteAreaText}"
                       Foreground="#555555"
                       Margin="0,0,0,12" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Anuluj"
                    Width="84"
                    Height="30"
                    Margin="0,0,8,0"
                    IsCancel="True" />
            <Button Content="Zapisz"
                    Width="84"
                    Height="30"
                    IsDefault="True"
                    Click="SaveButton_Click" />
        </StackPanel>

        <StackPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="160" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="34" />
                <RowDefinition Height="34" />
                <RowDefinition Height="34" />
                <RowDefinition Height="34" />
                <RowDefinition Height="34" />
            </Grid.RowDefinitions>

            <TextBlock Text="Min. powierzchnia biologicznie czynna [%]" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" Text="{Binding MinBioPercent, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" />
            <TextBlock Grid.Column="2" Text="{Binding RequiredMinBioAreaText}" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#555555" />

            <TextBlock Grid.Row="1" Text="Min. powierzchnia zabudowy [%]" VerticalAlignment="Center" />
            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding MinBuildingCoveragePercent, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" />
            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding RequiredMinBuildingAreaText}" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#555555" />

            <TextBlock Grid.Row="2" Text="Max. powierzchnia zabudowy [%]" VerticalAlignment="Center" />
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding MaxBuildingCoveragePercent, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" />
            <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding AllowedMaxBuildingAreaText}" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#555555" />

            <TextBlock Grid.Row="3" Text="Min. intensywnosc zabudowy" VerticalAlignment="Center" />
            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding MinIntensity, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" />
            <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding RequiredMinGfaText}" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#555555" />

            <TextBlock Grid.Row="4" Text="Max. intensywnosc zabudowy" VerticalAlignment="Center" />
            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding MaxIntensity, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" />
            <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding AllowedMaxGfaText}" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#555555" />
        </Grid>

        <TextBlock Text="Wartosci 0 oznaczaja brak sprawdzania danego warunku."
                   Margin="0,10,0,0"
                   Foreground="#555555" />

        </StackPanel>
    </DockPanel>
</Window>
