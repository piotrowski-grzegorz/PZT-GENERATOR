<Window x:Class="PztGenerator.AreaBalanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PZT - bilans obszarow"
        Width="960"
        Height="660"
        MinWidth="720"
        MinHeight="500"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <TextBlock Text="Bilans obszarow PZT"
                       FontSize="18"
                       FontWeight="SemiBold" />
            <TextBlock Text="{Binding SummaryText}"
                       Margin="0,4,0,0"
                       Foreground="#555555" />
            <TextBlock Text="{Binding BuildText}"
                       Margin="0,2,0,0"
                       FontSize="11"
                       Foreground="#777777" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0">
                <Button Content="Eksport CSV"
                        Width="110"
                        Height="28"
                        Margin="0,0,8,0"
                        Click="ExportCsvButton_Click" />
                <Button Content="Zamknij"
                        Width="92"
                        Height="28"
                        IsDefault="True"
                        Click="CloseButton_Click" />
            </StackPanel>
        </StackPanel>

        <TabControl>
            <TabItem Header="Bilans">
                <DockPanel Margin="0,10,0,0">
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border BorderBrush="#D0D0D0" BorderThickness="1" Padding="10" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Pow. zabudowy" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding BuildingFootprintText}" FontSize="16" />
                                <TextBlock Text="{Binding BuildingCoverageText}" Foreground="#555555" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" BorderBrush="#D0D0D0" BorderThickness="1" Padding="10" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Utwardzona" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding HardenedAreaText}" FontSize="16" />
                                <TextBlock Text="dojazdy, dojscia, parking" Foreground="#555555" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" BorderBrush="#D0D0D0" BorderThickness="1" Padding="10" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="PBC" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding BioAreaText}" FontSize="16" />
                                <TextBlock Text="{Binding BioPercentText}" Foreground="#555555" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3" BorderBrush="#D0D0D0" BorderThickness="1" Padding="10" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Intensywnosc" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding IntensityText}" FontSize="16" />
                                <TextBlock Text="{Binding GrossFloorAreaText}" Foreground="#555555" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="4" BorderBrush="#D0D0D0" BorderThickness="1" Padding="10">
                            <StackPanel>
                                <TextBlock Text="Miejsca" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding ParkingSpacesText}" FontSize="16" />
                                <TextBlock Text="{Binding ParkingAreaText}" Foreground="#555555" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <DataGrid ItemsSource="{Binding Rows}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Kategoria" Binding="{Binding Category}" Width="*" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120" />
                            <DataGridTextColumn Header="Szt." Binding="{Binding AreaCount}" Width="70" />
                            <DataGridTextColumn Header="Powierzchnia" Binding="{Binding AreaSquareMetersText}" Width="140" />
                            <DataGridTextColumn Header="Udzial dzialki" Binding="{Binding SiteShareText}" Width="120" />
                            <DataGridTextColumn Header="Informacje" Binding="{Binding DetailsText}" Width="260" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Walidacja MPZP">
                <ScrollViewer Margin="0,10,0,0" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ValidationMessages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#D0D0D0"
                                        BorderThickness="1"
                                        Background="{Binding Background}"
                                        Padding="10"
                                        Margin="0,0,0,6">
                                    <TextBlock Text="{Binding Text}"
                                               Foreground="{Binding Foreground}"
                                               TextWrapping="Wrap" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="MPZP">
                <DockPanel Margin="0,10,0,0">
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="Wymagania MPZP"
                                   FontSize="15"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding MpzpSettings.SiteAreaText}"
                                   Foreground="#555555"
                                   Margin="0,4,0,12" />
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Bottom"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,14,0,0">
                        <Button Content="Zapisz MPZP"
                                Width="110"
                                Height="28"
                                Click="SaveMpzpButton_Click" />
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="180" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="34" />
                            <RowDefinition Height="34" />
                            <RowDefinition Height="34" />
                            <RowDefinition Height="34" />
                            <RowDefinition Height="34" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Min. powierzchnia biologicznie czynna [%]" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding MpzpSettings.MinBioPercent, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding MpzpSettings.RequiredMinBioAreaText}" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#555555" />

                        <TextBlock Grid.Row="1" Text="Min. powierzchnia zabudowy [%]" VerticalAlignment="Center" />
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding MpzpSettings.MinBuildingCoveragePercent, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" />
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding MpzpSettings.RequiredMinBuildingAreaText}" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#555555" />

                        <TextBlock Grid.Row="2" Text="Max. powierzchnia zabudowy [%]" VerticalAlignment="Center" />
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding MpzpSettings.MaxBuildingCoveragePercent, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" />
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding MpzpSettings.AllowedMaxBuildingAreaText}" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#555555" />

                        <TextBlock Grid.Row="3" Text="Min. intensywnosc zabudowy" VerticalAlignment="Center" />
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding MpzpSettings.MinIntensity, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" />
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding MpzpSettings.RequiredMinGfaText}" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#555555" />

                        <TextBlock Grid.Row="4" Text="Max. intensywnosc zabudowy" VerticalAlignment="Center" />
                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding MpzpSettings.MaxIntensity, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" />
                        <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding MpzpSettings.AllowedMaxGfaText}" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#555555" />
                    </Grid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Parking">
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Miejsca parkingowe" FontSize="15" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding ParkingSpacesText}" Margin="0,8,0,0" FontSize="18" />
                        <TextBlock Text="{Binding ParkingAreaText}" Margin="0,4,0,0" Foreground="#555555" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Przyjete parametry" FontSize="15" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding ParkingSettingsText}" Margin="0,8,0,0" TextWrapping="Wrap" />
                        <TextBlock Text="Na tym etapie parametry sa domyslne dla raportu. Kolejny krok: edycja tych wartosci w tej zakladce i zapis w projekcie."
                                   Margin="0,12,0,0"
                                   Foreground="#555555"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Typy">
                <DockPanel Margin="0,10,0,0">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <TextBlock Text="Ustawienia typow PZT" FontSize="15" FontWeight="SemiBold" />
                        <TextBlock Text="Nazwa, kategoria i status sa stale. Edytuj tylko parametry obliczeniowe, zaznacz obszary w Revit i zastosuj wybrany typ."
                                   Margin="0,4,0,0"
                                   Foreground="#555555"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Bottom"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,10,0,0">
                        <Button Content="Zastosuj typ do zaznaczonych"
                                Width="190"
                                Height="28"
                                Click="ApplySelectedTypeButton_Click" />
                    </StackPanel>

                    <DataGrid x:Name="TypeRowsGrid"
                              ItemsSource="{Binding TypeRows}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              SelectionMode="Single"
                              SelectionUnit="FullRow">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Typ" Binding="{Binding Name}" IsReadOnly="True" Width="190" />
                            <DataGridTextColumn Header="Kategoria" Binding="{Binding Category}" IsReadOnly="True" Width="150" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" IsReadOnly="True" Width="120" />
                            <DataGridTextColumn Header="Kond." Binding="{Binding Floors, UpdateSourceTrigger=PropertyChanged}" Width="72" />
                            <DataGridTextColumn Header="Wys. kond. [m]" Binding="{Binding StoreyHeight, UpdateSourceTrigger=PropertyChanged}" Width="105" />
                            <DataGridTextColumn Header="Wsp. PBC" Binding="{Binding BioFactor, UpdateSourceTrigger=PropertyChanged}" Width="82" />
                            <DataGridTextColumn Header="Uwagi / opis" Binding="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Grafika">
                <DockPanel Margin="0,10,0,0">
                    <StackPanel DockPanel.Dock="Top"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,0,0,8">
                        <Button Content="Zastosuj style do regionow"
                                Width="180"
                                Height="28"
                                Click="ApplyGraphicsButton_Click" />
                    </StackPanel>

                    <DataGrid ItemsSource="{Binding GraphicRows}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Kolor" Width="58">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="26"
                                                Height="16"
                                                BorderBrush="#666666"
                                                BorderThickness="1"
                                                Background="{Binding Swatch}"
                                                HorizontalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Typ" Binding="{Binding Name}" Width="190" />
                            <DataGridTextColumn Header="Kategoria" Binding="{Binding Category}" Width="140" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110" />
                            <DataGridTextColumn Header="Styl obwiedni" Binding="{Binding LineStyleName}" Width="145" />
                            <DataGridTextColumn Header="Typ linii" Binding="{Binding LinePatternText}" Width="90" />
                            <DataGridTemplateColumn Header="Kolor linii" Width="78">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="26"
                                                Height="16"
                                                BorderBrush="#666666"
                                                BorderThickness="1"
                                                Background="{Binding LineSwatch}"
                                                HorizontalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Gr." Binding="{Binding BoundaryLineWeight}" Width="48" />
                            <DataGridTextColumn Header="Wypelnienie" Binding="{Binding FillPattern}" Width="120" />
                            <DataGridTextColumn Header="Opis" Binding="{Binding Description}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
